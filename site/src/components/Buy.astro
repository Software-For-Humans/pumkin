---
const STRIPE_URL = "https://buy.stripe.com/3cIeV77NK07s5UFcBq4Ja03";
// Default shown before the live count loads (and the no-JS fallback).
const DEFAULT_REMAINING = 50;
---

<section id="buy" class="section buy-section">
  <div class="container">
    <div class="buy-card panel">
      <img src="/mascot.png" alt="" class="pixel buy-mascot" width="200" height="200" />
      <div class="buy-header">
        <span class="eyebrow-buy" data-slots-eyebrow>founding license · <span data-slots-remaining>{DEFAULT_REMAINING}</span> of 50 remaining</span>
        <h2>Get Pumkin.</h2>
      </div>

      <div class="price">
        <span class="amount">$99</span>
        <span class="per">one-time · lifetime updates · all platforms</span>
      </div>

      <ul class="includes">
        <li>Windows installer today, macOS & Linux next, all included</li>
        <li>Lifetime updates for v0.x; free upgrade to v1.0</li>
        <li>Full source code for personal use and audit</li>
        <li>Direct email line to me — one founder, real support</li>
        <li>30-day refund, no questions asked</li>
      </ul>

      <a href={STRIPE_URL} class="btn btn-primary btn-buy" data-buy-btn>
        Buy Pumkin · $99
      </a>

      <p class="faint buy-meta">
        Price increases to $149 after the founding 50. Cap is hard — no exceptions.
      </p>
    </div>
  </div>
</section>

<script>
  // Live founding-slot counter. The page is static; this fetches the real
  // remaining count at runtime and updates every counter on the page.
  // Fails silently — if the fetch breaks, the static default stays.
  (async () => {
    try {
      const res = await fetch("/api/slots", { cache: "no-store" });
      if (!res.ok) return;
      const { remaining, total } = await res.json();
      if (typeof remaining !== "number") return;

      // Update every remaining-count element (hero + buy section)
      document.querySelectorAll("[data-slots-remaining]").forEach((el) => {
        el.textContent = String(remaining);
      });

      if (remaining <= 0) {
        // Sold out: relabel the eyebrows and disable the buy button
        document.querySelectorAll("[data-slots-eyebrow]").forEach((el) => {
          el.textContent = "founding licenses · sold out";
        });
        document.querySelectorAll("[data-buy-btn]").forEach((el) => {
          const a = el as HTMLAnchorElement;
          a.textContent = "Founding 50 sold out";
          a.removeAttribute("href");
          a.setAttribute("aria-disabled", "true");
          a.style.opacity = "0.6";
          a.style.pointerEvents = "none";
        });
      } else if (remaining <= 10) {
        // Low-stock nudge
        document.querySelectorAll("[data-slots-eyebrow]").forEach((el) => {
          el.textContent = `founding license · only ${remaining} of ${total} left`;
        });
      }
    } catch {
      /* keep static default */
    }
  })();
</script>

<style>
  .buy-section { padding: 6rem 0; }
  .buy-card {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    padding: 3rem 2.5rem 2.5rem;
    position: relative;
    box-shadow: 6px 6px 0 var(--brand-fg);
  }
  .buy-mascot {
    position: absolute;
    top: -96px;
    left: 50%;
    transform: translateX(-50%) rotate(-6deg);
    width: 192px;
    height: 192px;
    filter: drop-shadow(6px 6px 0 var(--brand-fg));
  }
  .buy-header {
    margin-top: 3rem;
    margin-bottom: 2rem;
  }
  .eyebrow-buy {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--brand-fg);
    background: var(--brand-accent);
    text-transform: lowercase;
    margin-bottom: 1.25rem;
    padding: 0.375rem 0.875rem;
    border: 2px solid var(--brand-fg);
    border-radius: 999px;
    font-weight: 600;
    box-shadow: 2px 2px 0 var(--brand-fg);
  }
  .price {
    margin-bottom: 2rem;
  }
  .price .amount {
    display: block;
    font-size: 4.5rem;
    font-weight: 800;
    color: var(--brand-fg);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .price .per {
    display: block;
    margin-top: 0.5rem;
    color: var(--brand-fg-muted);
    font-size: 0.875rem;
    font-weight: 500;
  }
  .includes {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    text-align: left;
    max-width: 380px;
    margin-left: auto;
    margin-right: auto;
  }
  .includes li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.625rem;
    font-size: 0.9375rem;
    color: var(--brand-fg);
  }
  .includes li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--brand-accent-quiet);
    font-weight: 800;
  }
  .btn-buy {
    padding: 1rem 2rem;
    font-size: 1.0625rem;
  }
  .buy-meta { margin-top: 1.5rem; }
</style>
