---
// src/components/Footer.astro
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img src="/mascot.png" alt="" class="pixel footer-mascot" width="128" height="128" />
      <div>
        <div class="footer-logo">pumkin</div>
        <div class="faint">indie agents, locally</div>
      </div>
    </div>
    <div class="footer-links">
      <a href="/docs/">docs</a>
      <a href="/brand">brand</a>
      <a href="/privacy">privacy</a>
      <a href="/terms">terms</a>
      <a href="https://github.com/Software-For-Humans/pumkin">github</a>
      <a href="mailto:hi@pumkin.app">hi@pumkin.app</a>
    </div>
    <div class="footer-credit faint">
      Made by <a href="https://swforhumans.com">Software For Humans, LLC</a> · Virginia · {new Date().getFullYear()}
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 2px solid var(--brand-fg);
    background: var(--brand-ink-deep);
    padding: 3rem 0;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }
  .footer-mascot {
    height: 128px;
    width: 128px;
  }
  .footer-logo {
    font-weight: 800;
    color: var(--brand-fg);
    font-size: 1.125rem;
    letter-spacing: -0.01em;
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.9375rem;
  }
  .footer-links a { color: var(--brand-fg); }
  .footer-links a:hover { color: var(--brand-accent-quiet); }
  .footer-credit { font-size: 0.8125rem; }
</style>
