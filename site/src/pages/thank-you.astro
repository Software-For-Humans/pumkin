---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { supabaseAdmin } from "../lib/supabase";

// Server-rendered — needs to read query param and look up the order
export const prerender = false;

interface OrderInfo {
  download_url: string;
  founding_no: number | null;
  version: string;
  email_sent: boolean;
}

const sessionId = Astro.url.searchParams.get("session_id");
let order: OrderInfo | null = null;
let lookupState: "ok" | "pending" | "invalid" | "missing" = "missing";

if (sessionId) {
  if (!sessionId.startsWith("cs_")) {
    lookupState = "invalid";
  } else {
    const { data } = await supabaseAdmin
      .from("pumkin_orders")
      .select("download_token, founding_no, version, status, email_sent_at")
      .eq("stripe_session", sessionId)
      .maybeSingle();

    if (!data) {
      lookupState = "pending";
    } else if (data.status !== "paid") {
      lookupState = "invalid";
    } else {
      lookupState = "ok";
      order = {
        download_url: `/api/download/${data.download_token}`,
        founding_no: data.founding_no,
        version: data.version,
        email_sent: !!data.email_sent_at,
      };
    }
  }
}
---

<Layout
  title="Welcome to Pumkin — Download"
  description="Thanks for buying Pumkin. Download the installer and get started."
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <Header />
  <main>
    {lookupState === "ok" && order && (
      <section class="thanks">
        <div class="container">
          <div class="thanks-card panel">
            <img src="/mascot.png" alt="" class="pixel thanks-mascot" width="160" height="160" />

            <span class="eyebrow-thanks">
              {order.founding_no
                ? `founding member · #${order.founding_no} of 50`
                : `welcome`}
            </span>
            <h1>You're in.</h1>
            <p class="lead">
              Thanks for buying Pumkin. Your founding license is good for
              lifetime updates on every platform we ship, forever.
            </p>

            <a href={order.download_url} class="btn btn-primary btn-download">
              ↓ Download Pumkin for Windows (v{order.version})
            </a>
            <p class="dl-meta faint">
              About 35 MB · NSIS installer · macOS & Linux builds will be
              emailed when they ship.
            </p>
            {order.email_sent && (
              <p class="dl-meta faint">
                We also emailed your download link in case you want it on
                another machine.
              </p>
            )}
          </div>
        </div>
      </section>
    )}

    {lookupState === "pending" && (
      <section class="thanks">
        <div class="container">
          <div class="thanks-card panel">
            <img src="/mascot.png" alt="" class="pixel thanks-mascot" width="160" height="160" />
            <h1>Almost there.</h1>
            <p class="lead">
              Stripe confirmed your payment, but we haven't finished processing
              yet. This usually takes a few seconds. Refresh this page in
              about 30 seconds, or check your email for a welcome message with
              your download link.
            </p>
            <a href={Astro.url.pathname + Astro.url.search} class="btn btn-primary btn-download">
              ↻ Refresh
            </a>
            <p class="dl-meta faint">
              If it's been more than a minute and your email hasn't arrived,
              reach out at <a href="mailto:hi@pumkin.app">hi@pumkin.app</a> with
              your receipt number and we'll get you sorted.
            </p>
          </div>
        </div>
      </section>
    )}

    {(lookupState === "invalid" || lookupState === "missing") && (
      <section class="thanks">
        <div class="container">
          <div class="thanks-card panel">
            <img src="/mascot.png" alt="" class="pixel thanks-mascot" width="160" height="160" />
            <h1>This page is for buyers.</h1>
            <p class="lead">
              If you've bought Pumkin, your download link was emailed directly
              and is also accessible from your Stripe receipt. Can't find it?
              Email <a href="mailto:hi@pumkin.app">hi@pumkin.app</a> with the
              email address you used and I'll resend.
            </p>
            <a href="/" class="btn btn-secondary btn-download">← Back to pumkin.app</a>
          </div>
        </div>
      </section>
    )}

    <section class="section quickstart">
      <div class="container prose">
        <h2>Quick start.</h2>
        <p class="muted">
          You need <a href="https://ollama.com/download" rel="noopener">Ollama</a>
          installed and at least one model pulled.
        </p>

        <ol class="steps">
          <li>
            <strong>Install Ollama.</strong> Download from
            <a href="https://ollama.com/download" rel="noopener">ollama.com</a>,
            run the installer. Ollama lives on localhost:11434.
          </li>
          <li>
            <strong>Pull a model.</strong> Open a terminal and run:
            <pre class="terminal-inline">ollama pull llama3.2:3b</pre>
            Pumkin lists all installed Ollama models in the agent picker.
          </li>
          <li>
            <strong>Run the Pumkin installer.</strong> Double-click the .exe
            you just downloaded. Windows may show a SmartScreen warning
            ("unknown publisher") — click "More info" → "Run anyway." Code
            signing is on the roadmap.
          </li>
          <li>
            <strong>Launch Pumkin.</strong> From the Start menu. First run
            shows a welcome screen and prompts you to create your first agent.
          </li>
        </ol>
      </div>
    </section>

    <section class="section help">
      <div class="container prose">
        <h2>Need help?</h2>
        <p class="muted">
          One human runs Pumkin. Email
          <a href="mailto:hi@pumkin.app">hi@pumkin.app</a> with anything —
          install issues, bug reports, feature requests, refund requests, "what
          model should I use for X." Replies usually within 24 hours.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .thanks { padding: 4rem 0; }
  .thanks-card {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    padding: 3rem 2.5rem;
    position: relative;
  }
  .thanks-mascot {
    width: 144px;
    height: 144px;
    margin: 0 auto 1rem;
    display: block;
    filter: drop-shadow(5px 5px 0 var(--brand-fg));
  }
  .eyebrow-thanks {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--brand-fg);
    background: var(--brand-accent);
    text-transform: lowercase;
    margin: 1rem 0 1.25rem;
    padding: 0.375rem 0.875rem;
    border: 2px solid var(--brand-fg);
    border-radius: 999px;
    font-weight: 600;
    box-shadow: 2px 2px 0 var(--brand-fg);
  }
  .lead {
    font-size: 1.0625rem;
    max-width: 480px;
    margin: 1rem auto 2rem;
    color: var(--brand-fg);
  }
  .btn-download {
    padding: 1.125rem 2rem;
    font-size: 1.0625rem;
    font-family: var(--font-mono);
  }
  .dl-meta { margin-top: 1rem; color: var(--brand-fg-muted); }

  .quickstart, .help { padding: 4rem 0; }
  .steps {
    list-style: none;
    padding: 0;
    margin-top: 2rem;
    counter-reset: step;
  }
  .steps li {
    counter-increment: step;
    padding: 1.25rem 0 1.25rem 3rem;
    position: relative;
    border-bottom: 1px solid var(--brand-border);
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--brand-fg);
  }
  .steps li:last-child { border-bottom: none; }
  .steps li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 1.25rem;
    background: var(--brand-accent);
    border: 2px solid var(--brand-fg);
    color: var(--brand-fg);
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    box-shadow: 2px 2px 0 var(--brand-fg);
  }
  .steps strong { color: var(--brand-fg); font-weight: 700; }
  .steps code {
    background: var(--brand-panel);
    border: 1px solid var(--brand-border);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.875rem;
  }
  .terminal-inline {
    background: var(--code-bg);
    color: var(--code-fg);
    border: 2px solid var(--brand-fg);
    border-radius: var(--radius);
    padding: 0.875rem 1.25rem;
    margin: 0.75rem 0;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    box-shadow: 3px 3px 0 var(--brand-fg);
  }
</style>
