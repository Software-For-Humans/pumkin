---
// src/layouts/DocsLayout.astro
// Shared shell for all /docs/* pages. Markdown files set this as their `layout`
// in frontmatter. Provides: brand header, sticky sidebar nav, prose content,
// prev/next-free simple structure, footer.
//
// To add a doc page: drop a new .md in src/pages/docs/ with the frontmatter
// layout + title, then add an entry to NAV below.

import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  frontmatter?: { title?: string; description?: string };
  title?: string;
  description?: string;
}

const fm = Astro.props.frontmatter ?? {};
const title = fm.title ?? Astro.props.title ?? "Docs";
const description =
  fm.description ?? Astro.props.description ?? "How to install and use Pumkin.";

// Sidebar structure. Order matters. `match` is compared against the current path.
const NAV = [
  {
    group: "Getting started",
    items: [
      { label: "Overview", href: "/docs/" },
      { label: "Install Ollama & models", href: "/docs/installing-ollama/" },
      { label: "Install Pumkin", href: "/docs/install-pumkin/" },
    ],
  },
  {
    group: "Using Pumkin",
    items: [
      { label: "Your first agent", href: "/docs/first-agent/" },
      { label: "MCP tools", href: "/docs/mcp-tools/" },
      { label: "Runs & threads", href: "/docs/runs-and-threads/" },
    ],
  },
  {
    group: "Help",
    items: [
      { label: "Troubleshooting", href: "/docs/troubleshooting/" },
      { label: "FAQ", href: "/docs/faq/" },
    ],
  },
];

// Normalize current path for active-link matching (strip trailing slash variance)
const current = Astro.url.pathname.replace(/\/+$/, "/") || "/";
const isActive = (href: string) =>
  current === href || current === href.replace(/\/$/, "");

const pageTitle = `${title} · Pumkin Docs`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#b5ddb5" />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og.png" />
  </head>
  <body>
    <Header />

    <div class="docs-shell container">
      <aside class="docs-sidebar">
        <nav class="docs-nav" aria-label="Documentation">
          {
            NAV.map((section) => (
              <div class="nav-group">
                <p class="nav-group-title">{section.group}</p>
                <ul>
                  {section.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class:list={["nav-link", { active: isActive(item.href) }]}
                        aria-current={isActive(item.href) ? "page" : undefined}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
          <div class="nav-group nav-help">
            <p class="nav-group-title">Stuck?</p>
            <p class="nav-help-text">
              Email <a href="mailto:hi@pumkin.app">hi@pumkin.app</a> — one founder, real
              answers, usually within a day.
            </p>
          </div>
        </nav>
      </aside>

      <main class="docs-main">
        <article class="prose docs-prose">
          <h1>{title}</h1>
          <slot />
        </article>
      </main>
    </div>

    <Footer />

    <style>
      .docs-shell {
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 3rem;
        padding-top: 3rem;
        padding-bottom: 4rem;
        align-items: start;
      }

      /* Sidebar */
      .docs-sidebar {
        position: sticky;
        top: 132px; /* below the 112px sticky header + breathing room */
        align-self: start;
      }
      .nav-group { margin-bottom: 1.75rem; }
      .nav-group-title {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--brand-fg-faint);
        margin-bottom: 0.625rem;
        font-weight: 600;
      }
      .nav-group ul { list-style: none; padding: 0; margin: 0; }
      .nav-group li { margin: 0; }
      .nav-link {
        display: block;
        padding: 0.375rem 0.75rem;
        margin: 0.0625rem 0;
        border-radius: 6px;
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--brand-fg);
        border: 2px solid transparent;
      }
      .nav-link:hover {
        background: var(--brand-ink-deep);
        color: var(--brand-fg);
      }
      .nav-link.active {
        background: var(--brand-accent);
        color: var(--brand-fg);
        border-color: var(--brand-fg);
        font-weight: 700;
        box-shadow: 2px 2px 0 var(--brand-fg);
      }
      .nav-help-text {
        font-size: 0.875rem;
        color: var(--brand-fg-muted);
        line-height: 1.55;
      }

      /* Content */
      .docs-main { min-width: 0; }
      .docs-prose { max-width: var(--content-width); }
      .docs-prose :global(h1) {
        font-size: clamp(2rem, 4vw, 2.75rem);
        margin-bottom: 1.25rem;
      }
      .docs-prose :global(h2) {
        font-size: 1.5rem;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--brand-border);
      }
      .docs-prose :global(h3) {
        font-size: 1.15rem;
        margin-top: 1.75rem;
        margin-bottom: 0.5rem;
      }
      .docs-prose :global(p),
      .docs-prose :global(li) {
        color: var(--brand-fg);
        line-height: 1.7;
      }
      .docs-prose :global(p) { margin-bottom: 1rem; }
      .docs-prose :global(ul),
      .docs-prose :global(ol) {
        margin: 0 0 1.25rem;
        padding-left: 1.5rem;
      }
      .docs-prose :global(li) { margin-bottom: 0.4rem; }
      .docs-prose :global(strong) { color: var(--brand-fg); font-weight: 700; }
      .docs-prose :global(a) { font-weight: 600; }
      .docs-prose :global(a:hover) { text-decoration: underline; }

      /* Inline code */
      .docs-prose :global(:not(pre) > code) {
        background: var(--brand-ink-deep);
        border: 1px solid var(--brand-border);
        padding: 0.1rem 0.4rem;
        border-radius: 4px;
        font-size: 0.875em;
        color: var(--brand-accent-quiet);
        font-weight: 600;
      }
      /* Code blocks */
      .docs-prose :global(pre) {
        background: var(--code-bg);
        color: var(--code-fg);
        border: 2px solid var(--brand-fg);
        border-radius: var(--radius);
        padding: 1.1rem 1.35rem;
        overflow-x: auto;
        font-size: 0.85rem;
        line-height: 1.6;
        margin: 0 0 1.5rem;
        box-shadow: 4px 4px 0 var(--brand-fg);
      }
      .docs-prose :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        color: inherit;
        font-weight: 400;
      }
      /* Blockquote — used for callouts/tips */
      .docs-prose :global(blockquote) {
        border-left: 4px solid var(--brand-accent);
        background: var(--brand-panel);
        padding: 0.875rem 1.25rem;
        margin: 0 0 1.5rem;
        border-radius: 0 6px 6px 0;
      }
      .docs-prose :global(blockquote p) { margin-bottom: 0; }
      /* Tables */
      .docs-prose :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 0 0 1.5rem;
        font-size: 0.9375rem;
      }
      .docs-prose :global(th),
      .docs-prose :global(td) {
        border: 1px solid var(--brand-border);
        padding: 0.5rem 0.75rem;
        text-align: left;
      }
      .docs-prose :global(th) {
        background: var(--brand-ink-deep);
        font-weight: 700;
      }
      .docs-prose :global(hr) {
        border: none;
        border-top: 1px solid var(--brand-border);
        margin: 2.5rem 0;
      }

      @media (max-width: 860px) {
        .docs-shell { grid-template-columns: 1fr; gap: 1.5rem; }
        .docs-sidebar {
          position: static;
          top: auto;
          border: 2px solid var(--brand-fg);
          border-radius: var(--radius);
          background: var(--brand-panel);
          padding: 1.25rem;
        }
      }
    </style>
  </body>
</html>
