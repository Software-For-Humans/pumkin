# Pumkin configuration — all optional, sensible defaults are built in.
# Copy to .env only if you need to override something.

# Path to the SQLite database file.
# Default: ./agentkit.db (relative to where you run it)
# AGENTKIT_DB=./agentkit.db

# URL of your local Ollama server.
# Default: http://localhost:11434
# OLLAMA_URL=http://localhost:11434
